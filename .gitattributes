# Normalize line endings: store LF in the repo, check out native on each OS.
* text=auto eol=lf

# Explicit text files
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.pdf       binary
